# Copy this file to .env and replace the placeholders with your Supabase project credentials.
# These variables are used by Vite during build and by serverless functions at runtime.
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_URL=https://your-project.supabase.co

# The values below are optional aliases used by serverless functions.
# They should match the VITE_ variables above.
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co

# Domain configuration
VITE_FULL_DOMAIN=mywardbulletin.com
VITE_SHORT_DOMAIN=mwbltn.com

# Branding (customize or leave empty to remove)
VITE_APP_NAME=MyWardBulletin
VITE_APP_TAGLINE=Ward Bulletin Creator
